def biner(desimal):
    st = stack()

    proses = []
    while desimal > 0:
        sisa = desimal % 2
        push(st, sisa)
        desimal = desimal // 2
        push(proses, f"Push stack with {sisa} ---> {st}")

    hasil = ""
    while not isEmpty(st):
        ambil = pop(st)
        hasil += str(ambil)
        push(proses, f"Pop stack with ---> {st}")

    return hasil, proses

